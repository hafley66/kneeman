[package]
name = "gdext-egui"
version = "0.4.1"
edition = "2021"
repository = "https://github.com/kang-sw/gdext-egui"
description = "egui bindings for gdext"
license = "MPL-2.0"

[workspace]
exclude = ["example/.rust"]

[dependencies]
godot =  "0.4"
egui = { version = "0.33" }

itertools = "0.14"

crossbeam-queue = "0.3"
oneshot = "0.2"

tap = "1"

derive_setters = "0.1"
educe = "0.6"

with_drop = "0"

open = "5"
